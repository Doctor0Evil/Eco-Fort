enum ColumnType2026v1
  String
  Int
  Float
  DateTime
  RiskCoord
  Residual
  Hex64
  Boolean
end

record ColumnSchema2026v1
  string schemashardid
  string targetshardfamily
  string targetversion
  int    colindex
  string colname
  ColumnType2026v1 coltype
  string alnvarid
  string units
  bool   mandatory
  bool   isriskcoord
  float  safeband_min
  float  safeband_max
  float  goldband_min
  float  goldband_max
  float  hardband_min
  float  hardband_max
  float  lyapweight
  int    lyapchannel
  string rustsymbol
  string csymbol
  string description
end

record ShardFamilySpec2026v1
  string familyid
  string csvpath
  string schemapath
  string lane_default
end

record SchemaShardRegistry2026v1
