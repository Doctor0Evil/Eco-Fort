spec AcceleratedAgingTranslation2026 v1.0.0
  purpose  Translation models mapping accelerated aging test results
           (ISO 4892-3, ISO 11357-3, OECD 310) to predicted field
           degradation metrics (t90, shedding rate) with quantified
           uncertainty. Phoenix-anchored via flow-adapted parameters.

  requires EcoNetSchemaShard2026 v1.0.0
  requires invariant kerdeployable v2.0.0

  shardschema
    path qpudatashards/translation/AcceleratedAgingTranslation2026v1.csv
    role AgingTranslationModel
    fields
      translation_model_id          -- string, unique ID
      substrate_material            -- string, PDMS|PET|PLA
      accelerated_test_standard     -- string, ISO 4892-3|ISO 11357-3|OECD 310
      uv_intensity_W_m2_nm340       -- float?, UV irradiance
      thermal_cycling_min_c         -- float?, min temp
      thermal_cycling_max_c         -- float?, max temp
      thermal_ramp_rate_c_per_min   -- float?, ramp rate
      hydrolysis_ph                 -- float?, pH
      hydrolysis_temp_c             -- float?, temperature
      flow_shear_stress_pa          -- float?, wall shear stress
      acceleration_factor           -- float, acceleration factor
      arrhenius_activation_energy_kJ_per_mol -- float?, Ea
      model_type                    -- string, Arrhenius|CumulativeDamage|ML_Surrogate
      predicted_t90_days_field      -- float, predicted field t90
      predicted_shedding_rate_field_mg_per_h_per_cm2 -- float, predicted shedding rate
      uncertainty_bounds_95pct      -- float, 95% CI half-width

      rtranslation_uncertainty      -- RiskCoord, model uncertainty risk
      rcalib                        -- RiskCoord, ingest quality

      vt                            -- Residual
      kscore                        -- float
      escore                        -- float
      rscore                        -- float
      dtdata                        -- float, 1 - rcalib
      lane                          -- string, RESEARCH only
      evidencehex                   -- hex64
      signinghex                    -- hex64

  corridors
    rtranslation_uncertainty
      safeband 0.0 0.10 goldband 0.10 0.13 hardband 0.13 1.00 lyapweight 0.7 channel dataquality
    rcalib
      safeband 0.0 0.00 goldband 0.00 0.04 hardband 0.13 1.00 lyapweight 0.8 channel dataquality

  writepolicy
    gate1_schema_from   EcoNetSchemaShard2026v1
    gate2_rcalib_gold   rcalib <= 0.04
    gate3_lane          lane == "RESEARCH"

  note This shard provides the translation layer between lab tests and
       field ecosafety predictions. High rtranslation_uncertainty may
       gate deployment by increasing vt and R.
end
