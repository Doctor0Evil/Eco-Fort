TITLE VirtaShardQueryRequest2026v1
VERSION 1
CATEGORY GOVERNANCE
SUMMARY "Request a filtered list of qpudatashards for wiring and evidence."

[fields]
repo_name      : string   # 'EcoNet'
primary_plane  : string   # 'hydraulics','energy','materials', etc.
region         : string   # 'Phoenix-AZ','Global','*' for any
preferred_role : string   # 'INGEST','KERNEL_INPUT','GOVERNANCE_LOG','DASHBOARD_SOURCE','*' for any
shard_kind     : string   # 'QPUDATASHARD','EVIDENCE','SCHEMA','*' for any
caller_system  : string
requested_at_utc : datetime
request_id     : string

[tags]
virta-sys
shard
catalog
request
