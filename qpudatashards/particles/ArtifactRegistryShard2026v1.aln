issuedutc 2026-05-02T23:10:00Z

enum ArtifactKind2026v1
  BINARY
  KERNEL
  ROUTINE
  QPUDATASHARD
  GOVLOG
  HEALTHCARE_PLAN
  INDEX_DB
endenum

enum Lane2026v1
  RESEARCH
  EXPPROD
  PROD
endenum

enum KerBand2026v1
  SAFE
  GUARDED
  BLOCKED
endenum

record ArtifactRegistryEntry2026v1
  artifactid       uint64

  repoid           uint64
  repofileid       uint64
  shardid          uint64    -- 0 if none
  catalogid        uint64    -- 0 if none
  mt6883registryid uint64    -- 0 if none

  repotarget       string
  destinationpath  string
  filename         string
  fileext          string
  artifactkind     ArtifactKind2026v1

  contenthash      string
  sizebytes        uint64

  primaryplane     string
  secondaryplanes  string
  lane             Lane2026v1
  kerband          KerBand2026v1
  planecontractid  uint64
  blastradiusid    uint64

  kmetric          float32
  emetric          float32
  rmetric          float32
  vtmax            float32
  kerdeployable    bool

  evidencehex      string
  rohanchorhex     string
  signingdid       string
  provenancehex    string

  createdutc       string
  updatedutc       string
  active           bool
endrecord

record ArtifactProvenanceEntry2026v1
  provenanceid     uint64
  artifactid       uint64

  cirunid          string
  workflowfile     string
  repo             string
  energymode       string
  status           string
  sharddbpath      string
  shardcount       uint64

  lane             Lane2026v1
  kmetric          float32
  emetric          float32
  rmetric          float32
  vtmax            float32
  kerdeployable    bool
  rtopology        float32
  wtopology        float32
  planecontractid  uint64

  evidencehex      string
  rohanchorhex     string
  signingdid       string
  timestamputc     string
endrecord

